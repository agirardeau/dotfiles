layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="zellij:tab-bar"
    }
    pane split_direction="vertical" {
      pane
      children
    }
    pane size=1 borderless=true {
      plugin location="zellij:status-bar"
    }
  }

  tab name="wt1" cwd="~/truehome/repos/agshared/wt1/aghub" {
    pane command="claude --name zorg-wt1"
  }
  tab name="main" cwd="~/truehome/repos/agshared/main/aghub" {
    pane
  }
}