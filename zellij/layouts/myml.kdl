pane_frames true
layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="zellij:tab-bar"
    }
    pane split_direction="vertical" {
      pane
      children
    }
    pane size=1 borderless=true {
      plugin location="zellij:status-bar"
    }
  }

  tab name="wt1" cwd="~/truehome/repos/myml/wt1" {
    pane command="claude" args="--name myml-wt1"
  }
  tab name="wt2" cwd="~/truehome/repos/myml/wt2/" {
    pane command="claude" args="--name myml-wt2"
  }
  tab name="main" cwd="~/truehome/repos/myml/main" {
    pane
  }
}
